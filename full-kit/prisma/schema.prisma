  enabled             Boolean             @default(false)
  rolloutPercent      Int                 @default(0) @map("rollout_percent")
  owner               String
  rationale           String              @db.Text
  matchDefinition     Json                @default("{}") @map("match_definition")
  evidenceRequired    Json                @default("{}") @map("evidence_required")
