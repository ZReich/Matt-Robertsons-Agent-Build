datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

// =============================================================================
// ENUMS
// =============================================================================

enum Category {
  business
  personal
}

enum DealStage {
  prospecting
  listing
  marketing
  showings
  offer
  under_contract
  due_diligence
  closing
  closed
}

enum DealType {
  seller_rep
  buyer_rep
  tenant_rep
}

enum DealOutcome {
  won
  lost
  withdrawn
  expired
}

enum DealSource {
  manual
  lead_derived
  buildout_event
  buyer_rep_inferred
  ai_suggestion
}

enum CanonicalDealStage {
  unknown
  prospect
  sourcing
  evaluating
  touring
  listing
  marketing
  loi_offer
  transacting
  under_contract
  due_diligence
  contingent
  closing
  closed
  dead
  nurture
  commission_realized
}

enum ContactPromotionCandidateStatus {
  pending
  needs_more_evidence
  snoozed
  approved
  merged
  rejected
  not_a_contact
  superseded
}

enum BuildoutEventKind {
  new_lead
  information_requested
  deal_stage_update
  task_assigned
  critical_date
  ca_executed
  document_view
  voucher_approved
  voucher_deposit
  commission_payment
  listing_expiration
  payment_event
  unknown_signal
}

enum BuildoutEventStatus {
  parsed
  matched
  needs_review
  proposed
  applied
  ignored
  superseded
  dead_letter
}

enum IntakeDispositionStatus {
  received
  normalized
  suppressed_noise
  filed_activity
  needs_human_gate
  queued_attention
  review_backlog
  dead_letter
  superseded
}

enum TodoReminderState {
  proposed
  active
  waiting_on_other
  snoozed
  due
  overdue
  done
  rejected
  superseded
}

enum AiFeedbackStatus {
  captured
  proposed_rule
  approved_rule
  rejected_rule
}

enum PropertyType {
  office
  retail
  industrial
  multifamily
  land
  mixed_use
  hospitality
  medical
  other
}

enum PropertyStatus {
  /// Available — no current closed deal, on the market.
  active
  /// Has a Deal in stage under_contract / closing / due_diligence.
  under_contract
  /// Has at least one LeaseRecord whose lease_end_date is in the future
  /// and whose status is not expired/terminated_early/renewed.
  leased
  /// Sold or transactionally completed — no active lease, has a won closed Deal.
  closed
  /// Removed from active view.
  archived
}

enum PendingReplyStatus {
  pending
  approved
  dismissed
}

enum CommunicationChannel {
  email
  call
  text
  whatsapp
  meeting
}

enum Direction {
  inbound
  outbound
}

enum TodoStatus {
  pending
  in_progress
  done
}

enum Priority {
  low
  medium
  high
  urgent
}

enum AgentTier {
  auto
  log_only
  approve
  blocked
}

enum AgentActionStatus {
  pending
  approved
  rejected
  executed
}

enum MemoryType {
  rule
  preference
  playbook
  client_note
  style_guide
}

enum SyncStatus {
  synced
  failed
  pending
  removed
}

enum QueueStatus {
  pending
  in_flight
  done
  failed
  /// Communication tripped the sensitive-content filter (financial keywords,
  /// SSN/routing/card patterns) and was deliberately skipped from AI scrub.
  /// The original email is unaffected; only the AI enrichment is bypassed.
  skipped_sensitive
}

enum LeadSource {
  crexi
  loopnet
  buildout
  email_cold
  referral
}

enum LeadStatus {
  new
  vetted
  contacted
  converted
  dropped
}

enum ClientType {
  prospect
  active_listing_client
  active_buyer_rep_client
  past_client
  past_listing_client
  past_buyer_client
  cooperating_broker
  service_provider
  other
}

enum EmailFilterRuleMode {
  draft
  classification_only
  observe_only
  quarantine_candidate
  promoted_exact
  limited_rollout
  active
  disabled
  retired
}

enum EmailBodyDecision {
  fetch_body
  metadata_only_quarantine
  safe_body_skip
}

enum EmailFilterRunMode {
  dry_run
  observe
  quarantine_only
  promoted_rules_limited
  active
}

enum EmailFilterAuditDisposition {
  observed
  quarantined
  fetched_body
  body_fetch_failed
  safe_skip_proposed
  safe_skip_applied
  restored
  false_negative
  true_noise
  uncertain
}

enum OperationalEmailReviewType {
  suspicious_noise
  never_queued
  missed_eligible
  orphaned_context
  failed_scrub
  stale_queue
  pending_mark_done
}

enum OperationalEmailReviewStatus {
  open
  resolved
  snoozed
  ignored
}

// =============================================================================
// AUTH MODELS (existing — do not modify, required by NextAuth/PrismaAdapter)
// =============================================================================

model User {
  id                   String          @id @default(uuid())
  name                 String
  username             String?         @unique
  email                String?         @unique
  emailVerifyToken     String?
  emailVerified        DateTime?
  password             String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  avatar               String?
  profileBackground    String?
  status               String          @default("ONLINE")
  preferences          UserPreference?
  accounts             Account[]
  sessions             Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name, username, status, createdAt])
}

model UserPreference {
  id        String  @id @default(uuid())
  theme     String
  mode      String
  radius    String
  layout    String
  direction String
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String? @unique
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// CRE BUSINESS MODELS
// =============================================================================

/// Unified people table — both business clients and personal contacts.
/// Use `category` to distinguish business vs personal.
model Contact {
  id               String      @id @default(uuid())
  name             String
  company          String?
  email            String?
  phone            String?
  role             String? // e.g., "investor", "tenant", "dentist", "family"
  preferredContact String?     @map("preferred_contact") // email, phone, text, whatsapp
  address          String?
  notes            String?     @db.Text
  category         Category    @default(business)
  tags             Json?       @default("[]") // JSON array of tag strings
  createdBy        String?     @map("created_by") // "user:<id>" or "agent"
  archivedAt       DateTime?   @map("archived_at")
  leadSource       LeadSource? @map("lead_source")
  leadStatus       LeadStatus? @map("lead_status")
  leadAt           DateTime?   @map("lead_at")
  leadLastViewedAt DateTime?   @map("lead_last_viewed_at")
  estimatedValue   Decimal?    @map("estimated_value") @db.Decimal(14, 2)
  clientType       ClientType? @map("client_type")
  /// Buyer/tenant search criteria for matching against the Property catalog.
  /// Shape: { propertyTypes: PropertyType[], minSqft?: number, maxSqft?: number,
  ///          locations: string[], maxPrice?: number, minPrice?: number, notes?: string }
  searchCriteria   Json?       @map("search_criteria")

  // Relations
  deals          Deal[]
  communications Communication[]
  meetings       MeetingAttendee[]
  todos          Todo[]
  agentMemories  AgentMemory[]
  profileFacts   ContactProfileFact[]
  pendingReplies PendingReply[]               @relation("PendingReplyContact")
  leaseRecords   LeaseRecord[]
  calendarEvents CalendarEvent[]
  backfillRuns   BackfillRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([company])
  @@index([category])
  @@index([leadSource])
  @@index([leadStatus])
  @@index([leadStatus, updatedAt])
  @@index([leadSource, leadStatus, leadLastViewedAt])
  @@index([clientType])
  @@map("contacts")
}

model ContactProfileFact {
  id                    String    @id @default(uuid())
  contactId             String    @map("contact_id")
  category              String
  fact                  String    @db.Text
  normalizedKey         String    @map("normalized_key")
  confidence            Decimal   @db.Decimal(5, 4)
  wordingClass          String    @map("wording_class")
  sourceCommunicationId String    @map("source_communication_id")
  sourceAgentActionId   String?   @map("source_agent_action_id")
  observedAt            DateTime  @default(now()) @map("observed_at")
  lastSeenAt            DateTime  @default(now()) @map("last_seen_at")
  expiresAt             DateTime? @map("expires_at")
  status                String    @default("active")
  metadata              Json?     @default("{}")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([contactId, normalizedKey])
  @@index([contactId, category])
  @@index([sourceCommunicationId])
  @@index([status])
  @@map("contact_profile_facts")
}

/// CRE deals — the core pipeline entity
model Deal {
  id              String        @id @default(uuid())
  contactId       String        @map("contact_id")
  propertyAddress String?       @map("property_address")
  propertyType    PropertyType? @map("property_type")
  squareFeet      Int?          @map("square_feet")
  stage           DealStage     @default(prospecting)
  value           Decimal?      @db.Decimal(14, 2)
  listedDate      DateTime?     @map("listed_date")
  closingDate     DateTime?     @map("closing_date")
  closedAt        DateTime?     @map("closed_at")
  outcome         DealOutcome?
  dealType        DealType      @default(seller_rep) @map("deal_type")
  dealSource      DealSource    @default(manual) @map("deal_source")
  propertyKey     String?       @map("property_key")
  propertyAliases Json?         @default("[]") @map("property_aliases")
  unit            String?
  searchCriteria  Json?         @map("search_criteria")
  keyContacts     Json?         @default("{}") @map("key_contacts")
  category        Category      @default(business)
  tags            Json?         @default("[]")
  notes           String?       @db.Text
  createdBy       String?       @map("created_by")
  archivedAt      DateTime?     @map("archived_at")
  commissionRate  Decimal?      @default(0.03) @map("commission_rate") @db.Decimal(5, 4)
  probability     Int?
  stageChangedAt  DateTime?     @map("stage_changed_at")
  /// Optional FK back to the Property catalog. Lets a Deal denormalize-link
  /// to the canonical Property record when the catalog has it. Existing
  /// embedded propertyAddress/propertyType/squareFeet remain authoritative
  /// while the catalog is being seeded.
  propertyId      String?       @map("property_id")
  /// Buildout's internal deal ID. Set when a Deal is ingested from a
  /// Buildout export CSV. Unique so re-running the ingest is idempotent —
  /// re-runs UPSERT by this key. Null for AI-detected and manually-created
  /// deals.
  buildoutDealId  String?       @unique @map("buildout_deal_id")

  // Relations
  contact        Contact         @relation(fields: [contactId], references: [id], onDelete: Restrict)
  property       Property?       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  documents      DealDocument[]
  communications Communication[]
  meetings       Meeting[]
  todos          Todo[]
  agentMemories  AgentMemory[]
  leaseRecords   LeaseRecord[]
  calendarEvents CalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([stage])
  @@index([propertyType])
  @@index([propertyAddress])
  /// @prisma-unique-partial: deal_type='seller_rep' AND archived_at IS NULL AND property_key IS NOT NULL
  /// Partial unique index `deals_property_key_seller_rep_active_uidx` enforces
  /// this in Postgres (see migration 20260430140000_deals_property_key_unique).
  /// Prisma's schema DSL can't express partial unique indexes, so this is
  /// document-only — the constraint is created via raw SQL migration.
  @@index([propertyKey])
  @@index([dealType])
  @@index([dealSource])
  @@index([closedAt])
  @@index([listedDate])
  @@index([closingDate])
  @@index([stageChangedAt])
  @@index([propertyId])
  @@map("deals")
}

/// Documents/files attached to deals
model DealDocument {
  id        String   @id @default(uuid())
  dealId    String   @map("deal_id")
  name      String
  docType   String   @map("doc_type") // contract, inspection, financial, title, marketing, correspondence, other
  url       String? // cloud storage URL (Google Drive, S3, etc.)
  notes     String?
  dateAdded DateTime @default(now()) @map("date_added")

  // Relations
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([docType])
  @@map("deal_documents")
}

/// All communications: calls, texts, emails, WhatsApp, etc.
/// Primary table for Plaud transcripts, email bodies, SMS content.
model Communication {
  id                String               @id @default(uuid())
  channel           CommunicationChannel
  subject           String?
  body              String?              @db.Text // full transcript, email body, text content
  date              DateTime
  direction         Direction?
  category          Category             @default(business)
  tags              Json?                @default("[]")
  metadata          Json?                @default("{}") // flexible: extra channel-specific data
  durationSeconds   Int?                 @map("duration_seconds") // for calls
  externalMessageId String?              @map("external_message_id") // gmail msg id, etc.
  conversationId    String?              @map("conversation_id")
  createdBy         String?              @map("created_by")
  archivedAt        DateTime?            @map("archived_at")

  // Who and what this relates to
  contactId String? @map("contact_id")
  dealId    String? @map("deal_id")

  // Which agent action created this (if auto-generated)
  agentActionId String? @unique @map("agent_action_id")

  // Relations
  contact            Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal               Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  agentAction        AgentAction?  @relation("CreatedCommunicationAction", fields: [agentActionId], references: [id], onDelete: SetNull)
  sourceAgentActions AgentAction[] @relation("SourceCommunicationAction")

  // Link to external sync record (for Plaud, Gmail, etc.)
  externalSyncId String?       @unique @map("external_sync_id")
  externalSync   ExternalSync? @relation(fields: [externalSyncId], references: [id])

  // Todos that were created from this communication
  todos                   Todo[]
  scrubQueue              ScrubQueue?
  operationalEmailReviews OperationalEmailReview[]
  triggeredPendingReplies PendingReply[]            @relation("PendingReplyTrigger")
  approvedFromPendingReply PendingReply[]           @relation("PendingReplyApproved")
  sourceLeaseRecords      LeaseRecord[]             @relation("LeaseRecordSourceComm")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channel])
  @@index([date])
  @@index([contactId])
  @@index([dealId])
  @@index([direction])
  @@index([category])
  @@index([externalMessageId])
  @@index([conversationId])
  @@map("communications")
}

model IntakeDisposition {
  id               String                  @id @default(uuid())
  sourceSystem     String                  @map("source_system")
  sourceExternalId String                  @map("source_external_id")
  communicationId  String?                 @map("communication_id")
  status           IntakeDispositionStatus
  reasonCode       String                  @map("reason_code")
  confidence       Decimal?                @db.Decimal(5, 4)
  processor        String
  processorVersion String                  @map("processor_version")
  childRefs        Json?                   @default("[]") @map("child_refs")
  retryCount       Int                     @default(0) @map("retry_count")
  lastError        String?                 @map("last_error") @db.Text
  metadata         Json?                   @default("{}")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  @@unique([sourceSystem, sourceExternalId])
  @@index([communicationId])
  @@index([status])
  @@map("intake_dispositions")
}

model IdentityCandidateGroup {
  id                String                          @id @default(uuid())
  status            ContactPromotionCandidateStatus @default(pending)
  displayName       String?                         @map("display_name")
  normalizedEmails  Json?                           @default("[]") @map("normalized_emails")
  normalizedPhones  Json?                           @default("[]") @map("normalized_phones")
  aliases           Json?                           @default("[]")
  companies         Json?                           @default("[]")
  evidence          Json?                           @default("[]")
  possibleContactId String?                         @map("possible_contact_id")
  approvedContactId String?                         @map("approved_contact_id")
  confidenceScore   Decimal?                        @map("confidence_score") @db.Decimal(5, 4)
  snoozedUntil      DateTime?                       @map("snoozed_until")
  metadata          Json?                           @default("{}")
  createdAt         DateTime                        @default(now()) @map("created_at")
  updatedAt         DateTime                        @updatedAt @map("updated_at")

  @@index([status])
  @@index([possibleContactId])
  @@index([approvedContactId])
  @@map("identity_candidate_groups")
}

model ContactPromotionCandidate {
  id                       String                          @id @default(uuid())
  identityCandidateGroupId String?                         @map("identity_candidate_group_id")
  normalizedEmail          String?                         @map("normalized_email")
  displayName              String?                         @map("display_name")
  company                  String?
  phone                    String?
  message                  String?                         @db.Text
  source                   String
  sourcePlatform           String?                         @map("source_platform")
  sourceKind               String?                         @map("source_kind")
  status                   ContactPromotionCandidateStatus @default(pending)
  confidenceScore          Decimal?                        @map("confidence_score") @db.Decimal(5, 4)
  evidenceCount            Int                             @default(1) @map("evidence_count")
  firstSeenAt              DateTime                        @default(now()) @map("first_seen_at")
  lastSeenAt               DateTime                        @default(now()) @map("last_seen_at")
  suggestedContactId       String?                         @map("suggested_contact_id")
  approvedContactId        String?                         @map("approved_contact_id")
  communicationId          String?                         @map("communication_id")
  agentActionId            String?                         @map("agent_action_id")
  dedupeKey                String                          @unique @map("dedupe_key")
  snoozedUntil             DateTime?                       @map("snoozed_until")
  metadata                 Json?                           @default("{}")
  createdAt                DateTime                        @default(now()) @map("created_at")
  updatedAt                DateTime                        @updatedAt @map("updated_at")

  @@index([identityCandidateGroupId])
  @@index([normalizedEmail])
  @@index([status])
  @@index([snoozedUntil])
  @@index([communicationId])
  @@map("contact_promotion_candidates")
}

model BuildoutProperty {
  id                    String              @id @default(uuid())
  buildoutPropertyId    String?             @unique @map("buildout_property_id")
  buildoutDealId        String?             @unique @map("buildout_deal_id")
  propertyNameRaw       String?             @map("property_name_raw")
  propertyAddressRaw    String?             @map("property_address_raw")
  normalizedPropertyKey String              @map("normalized_property_key")
  aliases               Json?               @default("[]")
  unitOrSuite           String              @default("") @map("unit_or_suite")
  currentStage          CanonicalDealStage? @map("current_stage")
  status                String              @default("unknown")
  source                String              @default("email_event")
  assignedToMatt        Boolean             @default(false) @map("assigned_to_matt")
  teamMembers           Json?               @default("[]") @map("team_members")
  sourceRecipients      Json?               @default("[]") @map("source_recipients")
  lastBuildoutEventAt   DateTime?           @map("last_buildout_event_at")
  matchedDealId         String?             @map("matched_deal_id")
  matchConfidence       Decimal?            @map("match_confidence") @db.Decimal(5, 4)
  metadata              Json?               @default("{}")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@unique([normalizedPropertyKey, unitOrSuite])
  @@index([matchedDealId])
  @@map("buildout_properties")
}

/// Catalog of properties Matt is listing or has listed. Distinct from `Deal`
/// in that a Property can exist without any inquiry/deal yet. Genevieve's
/// spreadsheet of active/under-contract/closed listings is the seed source.
/// `propertyKey` is the normalized address used to join with Deal.propertyKey
/// and inbound lead emails.
model Property {
  id                  String         @id @default(uuid())
  name                String?
  address             String
  unit                String?
  city                String?
  state               String?
  zip                 String?
  propertyKey         String         @map("property_key")
  propertyType        PropertyType?  @map("property_type")
  status              PropertyStatus @default(active)
  squareFeet          Int?           @map("square_feet")
  occupiedSquareFeet  Int?           @map("occupied_square_feet")
  listPrice           Decimal?       @map("list_price") @db.Decimal(14, 2)
  capRate             Decimal?       @map("cap_rate") @db.Decimal(7, 4)
  listingUrl          String?        @map("listing_url")
  flyerUrl            String?        @map("flyer_url")
  description         String?        @db.Text
  highlights          Json?          @default("[]")
  tags                Json?          @default("[]")
  source              String?        // "buildout", "loopnet", "crexi", "manual", "csv_import"
  externalId          String?        @map("external_id")
  notes               String?        @db.Text
  createdBy           String?        @map("created_by")
  archivedAt          DateTime?      @map("archived_at")
  listedAt            DateTime?      @map("listed_at")
  underContractAt     DateTime?      @map("under_contract_at")
  closedAt            DateTime?      @map("closed_at")

  deals          Deal[]
  pendingReplies PendingReply[]
  leaseRecords   LeaseRecord[]
  calendarEvents CalendarEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([propertyKey, unit])
  @@index([status])
  @@index([propertyType])
  @@index([propertyKey])
  @@index([archivedAt])
  @@map("properties")
}

/// Auto-generated draft email replies awaiting human review.
/// Created when an inbound lead inquiry matches a Property in our catalog.
/// `status="pending"` is reviewable; "approved" means Matt accepted; "dismissed"
/// means the auto-draft was rejected. We deliberately do NOT send mail from
/// this model — the Communication row with direction="outbound" is created
/// only after human approval, so this is a safe scaffold for the real send-
/// mail wiring later.
model PendingReply {
  id                      String             @id @default(uuid())
  triggerCommunicationId  String?            @map("trigger_communication_id")
  contactId               String?            @map("contact_id")
  propertyId              String?            @map("property_id")
  draftSubject            String             @map("draft_subject")
  draftBody               String             @db.Text @map("draft_body")
  reasoning               String?            @db.Text
  suggestedProperties     Json?              @default("[]") @map("suggested_properties")
  modelUsed               String?            @map("model_used")
  status                  PendingReplyStatus @default(pending)
  approvedAt              DateTime?          @map("approved_at")
  approvedBy              String?            @map("approved_by")
  dismissedAt             DateTime?          @map("dismissed_at")
  dismissReason           String?            @map("dismiss_reason")
  approvedCommunicationId String?            @map("approved_communication_id")
  /// Optional FK back to the LeaseRecord that triggered this re-engagement
  /// draft. Lets the UI on the LeaseRecord detail surface its renewal-
  /// outreach history. Null for non-renewal drafts.
  leaseRecordId           String?            @map("lease_record_id")

  property              Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  contact               Contact?       @relation("PendingReplyContact", fields: [contactId], references: [id], onDelete: SetNull)
  triggerCommunication  Communication? @relation("PendingReplyTrigger", fields: [triggerCommunicationId], references: [id], onDelete: SetNull)
  approvedCommunication Communication? @relation("PendingReplyApproved", fields: [approvedCommunicationId], references: [id], onDelete: SetNull)
  leaseRecord           LeaseRecord?   @relation("LeaseRenewalReply", fields: [leaseRecordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([contactId])
  @@index([propertyId])
  /// @prisma-unique-partial: trigger_communication_id IS NOT NULL AND contact_id IS NOT NULL AND property_id IS NOT NULL
