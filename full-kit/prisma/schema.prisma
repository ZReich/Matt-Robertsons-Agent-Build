/// Calendar events and meetings
model Meeting {
  id              String    @id @default(uuid())
  title           String
  date            DateTime
  endDate         DateTime? @map("end_date")
  durationMinutes Int?      @map("duration_minutes")
  location        String?
  notes           String?   @db.Text
  category        Category  @default(business)
  tags            Json?     @default("[]")
  metadata        Json?     @default("{}") // { google_calendar_id, zoom_link, etc. }
  createdBy       String?   @map("created_by")
  archivedAt      DateTime? @map("archived_at")

  dealId String? @map("deal_id")

  // Which agent action created this (if auto-generated)
  agentActionId String? @unique @map("agent_action_id")

  // Relations
  deal        Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  agentAction AgentAction?      @relation(fields: [agentActionId], references: [id], onDelete: SetNull)
