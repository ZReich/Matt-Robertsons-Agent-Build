  redactedBodyStorageLocation String?   @map("redacted_body_storage_location")
  redactedBody                String?   @map("redacted_body") @db.Text
  bodyHash                    String?   @map("body_hash")
  bodyLength                  Int       @default(0) @map("body_length")
  bodyContentType             String?   @map("body_content_type")
  redactionVersion            String?   @map("redaction_version")
  redactionStatus             String    @default("not_required") @map("redaction_status")
  redactionError              String?   @map("redaction_error") @db.Text
  accessPolicy                String?   @map("access_policy")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  @@index([externalSyncId])
  @@index([communicationId])
  @@index([runId, chunkId])
  @@map("email_raw_body_retention")
}

model EmailGraphCursorState {
  id                   String    @id @default(uuid())
  mailboxId            String    @map("mailbox_id")
  folder               String
  mode                 String
  deltaLink            String?   @map("delta_link") @db.Text
  nextLink             String?   @map("next_link") @db.Text
  cursorVersion        Int       @default(1) @map("cursor_version")
  lastCommittedRunId   String?   @map("last_committed_run_id")
  lastCommittedChunkId String?   @map("last_committed_chunk_id")
  cursorStatus         String    @default("active") @map("cursor_status")
  lastSuccessfulSyncAt DateTime? @map("last_successful_sync_at")
  lastErrorAt          DateTime? @map("last_error_at")
  lastError            String?   @map("last_error") @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@unique([mailboxId, folder, mode])
  @@index([cursorStatus])
  @@map("email_graph_cursor_state")
}

model SystemState {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_state")
}

// =============================================================================
// EXTERNAL INTEGRATIONS / SYNC TRACKING
// =============================================================================

/// Tracks external records imported from Plaud, Gmail, Google Calendar, etc.
/// Prevents duplicate imports and enables incremental sync.
model ExternalSync {
  id         String     @id @default(uuid())
  source     String // plaud, gmail, google-calendar, twilio, etc.
  externalId String     @map("external_id") // ID from the external system
  entityType String?    @map("entity_type") // communication, meeting, todo, deal
  entityId   String?    @map("entity_id") // UUID of the created entity
  syncedAt   DateTime   @default(now()) @map("synced_at")
  rawData    Json?      @map("raw_data") // original API response for debugging
  status     SyncStatus @default(synced)
  errorMsg   String?    @map("error_msg") @db.Text

  // Direct link back to communication (most common case)
  communication Communication?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, externalId])
  @@index([source])
  @@index([syncedAt])
  @@index([status])
  @@index([entityType, entityId])
  @@map("external_sync")
}

/// Integration credentials — store API tokens for external services
/// NOTE: The `credentials` JSON MUST be encrypted at the application layer
/// before writing. Never store plaintext tokens.
model IntegrationCredential {
  id            String    @id @default(uuid())
  service       String    @unique // plaud, gmail, google-calendar, etc.
  credentials   Json // { accessToken, refreshToken, expiresAt, ... } — ENCRYPTED
  scopes        String[]  @default([]) // permissions this credential grants
  encryptedAt   DateTime? @map("encrypted_at") // when credentials were last encrypted
  lastRefreshed DateTime? @map("last_refreshed")
  isActive      Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integration_credentials")
}

/// LeaseRecord — one row per closed lease (or sale) extracted from email.
/// Drives the renewal-alert pipeline. Created by the lease-extractor AI
/// pass; never edited by hand except via the UI's correction flow.
///
/// `leaseEndDate` is the trigger for the renewal-alert sweep: the daily
/// cron looks for records where leaseEndDate is approaching (configurable
/// lookahead, default 6 months) and creates a Todo + CalendarEvent + auto-
/// drafted re-engagement PendingReply.
///
/// For sales (not leases), leaseEndDate is null but closeDate is populated.
/// Sales rows still drive Contact.clientType updates and the Christmas-
/// mailer cohort but don't trigger renewal alerts.
model LeaseRecord {
  id                    String         @id @default(uuid())
  contactId             String         @map("contact_id")
  propertyId            String?        @map("property_id")
  dealId                String?        @map("deal_id")
  sourceCommunicationId String?        @map("source_communication_id")
  closeDate             DateTime?      @map("close_date")
  leaseStartDate        DateTime?      @map("lease_start_date")
  leaseEndDate          DateTime?      @map("lease_end_date")
  leaseTermMonths       Int?           @map("lease_term_months")
  rentAmount            Decimal?       @map("rent_amount") @db.Decimal(14, 2)
  rentPeriod            String?        @map("rent_period")
  /// Which side of the deal Matt represented. Drives the re-engagement
  /// language (different pitch for owner-side vs tenant-side).
  mattRepresented       String?        @map("matt_represented")
  /// Sale vs lease vs unknown. Sales never trigger renewal alerts; they
  /// just feed Contact.clientType + Christmas-mailer cohort.
  dealKind              String         @default("lease") @map("deal_kind")
  /// Confidence score 0.0-1.0 from the AI extraction. Below 0.6 surfaces
  /// to a human-review queue rather than auto-creating side effects.
  extractionConfidence  Decimal        @default(0.0) @map("extraction_confidence") @db.Decimal(5, 4)
  status                String         @default("active")
  notes                 String?        @db.Text
  metadata              Json?          @default("{}")

  contact               Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property              Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  deal                  Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  sourceCommunication   Communication? @relation("LeaseRecordSourceComm", fields: [sourceCommunicationId], references: [id], onDelete: SetNull)
  calendarEvents        CalendarEvent[]
  renewalReplies        PendingReply[] @relation("LeaseRenewalReply")

  createdBy             String?        @map("created_by")
  archivedAt            DateTime?      @map("archived_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  @@index([contactId])
  @@index([leaseEndDate])
  @@index([status])
  @@index([closeDate])
  @@index([propertyId])
  @@index([dealId])
  // DB-side dedupe matching the orchestrator's `buildLeaseRecordWhere`.
  // Both kinds key on (contactId, propertyId, dateDim) so that two
  // distinct sales/leases of different properties closing on the same
  // day are NOT collapsed.
  //
  // NOTE (audit I1): the actual DB constraints are PARTIAL unique indexes:
  //   lease_record_dedupe_lease  WHERE archived_at IS NULL AND lease_start_date IS NOT NULL
  //   lease_record_dedupe_sale   WHERE archived_at IS NULL AND close_date    IS NOT NULL
  // Postgres treats NULL as distinct in unique constraints, so without
  // the IS NOT NULL clause two rows with a null date dimension would not
  // be deduped. The archived_at clause lets us recreate a key after
  // archiving the prior LeaseRecord. The Prisma @@unique declarations are
  // KEPT here so Prisma's upsert continues to recognize the columns; the
  // partial WHERE clause is enforced by migration
  // 20260503150000_lease_record_partial_dedupe. `prisma migrate diff` will
  // report the WHERE clause as drift — that drift is intentional.
  @@unique([contactId, propertyId, leaseStartDate], map: "lease_record_dedupe_lease")
  @@unique([contactId, propertyId, closeDate], map: "lease_record_dedupe_sale")
  @@map("lease_records")
}

/// CalendarEvent — system-generated calendar entries (lease renewals,
/// follow-ups, anniversaries). Distinct from `Meeting` which represents
/// actual scheduled interactions with attendees. The Calendar UI merges
/// both into a unified view.
model CalendarEvent {
  id              String       @id @default(uuid())
  title           String
  description     String?      @db.Text
  startDate       DateTime     @map("start_date")
  endDate         DateTime?    @map("end_date")
  allDay          Boolean      @default(true) @map("all_day")
  /// Type of automated event — drives icon + color in the UI.
  /// Examples: "lease_renewal", "follow_up", "anniversary", "tax_deadline".
  eventKind       String       @map("event_kind")
  contactId       String?      @map("contact_id")
  dealId          String?      @map("deal_id")
  propertyId      String?      @map("property_id")
  leaseRecordId   String?      @map("lease_record_id")
  /// "system" for AI-generated, "manual" for hand-added.
  source          String       @default("system")
  status          String       @default("upcoming")

  contact         Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal            Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  property        Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  leaseRecord     LeaseRecord? @relation(fields: [leaseRecordId], references: [id], onDelete: SetNull)

  createdBy       String?      @map("created_by")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([startDate])
  @@index([eventKind])
  @@index([leaseRecordId])
  @@index([contactId])
  @@index([dealId])
  // PARTIAL unique index — see migration 20260503150000_lease_record_partial_dedupe.
  // WHERE lease_record_id IS NOT NULL so unrelated CalendarEvent rows
  // (no underlying LeaseRecord) aren't deduped against each other.
  @@unique([leaseRecordId, eventKind], map: "calendar_event_dedupe_kind")
  @@map("calendar_events")
}
