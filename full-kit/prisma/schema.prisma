/// Agent actions — the approval queue for AI-generated tasks
model AgentAction {
  id           String            @id @default(uuid())
  actionType   String            @map("action_type") // create-todo, update-deal, send-email, etc.
  tier         AgentTier
  status       AgentActionStatus @default(pending)
  summary      String // human-readable description
  targetEntity String?           @map("target_entity") // e.g., "deal:<uuid>" or "contact:<uuid>"
  payload      Json?             @default("{}") // structured action data
  feedback     String?           @db.Text

  executedAt            DateTime? @map("executed_at")
  sourceCommunicationId String?   @map("source_communication_id")
  promptVersion         String    @default("unknown") @map("prompt_version")
  duplicateOfActionId   String?   @map("duplicate_of_action_id")
  dedupedToTodoId       String?   @map("deduped_to_todo_id")

  // Relations: which entity did this action create?
  todo                    Todo?
  communication           Communication?           @relation("CreatedCommunicationAction")
  meeting                 Meeting?
  memory                  AgentMemory?
  sourceCommunication     Communication?           @relation("SourceCommunicationAction", fields: [sourceCommunicationId], references: [id], onDelete: SetNull)
  duplicateOfAction       AgentAction?             @relation("AgentActionDuplicate", fields: [duplicateOfActionId], references: [id], onDelete: SetNull)
  duplicateActions        AgentAction[]            @relation("AgentActionDuplicate")
  dedupedToTodo           Todo?                    @relation("DedupedTodoAction", fields: [dedupedToTodoId], references: [id], onDelete: SetNull)
  operationalEmailReviews OperationalEmailReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([tier])
  @@index([actionType])
  @@index([createdAt])
  @@index([sourceCommunicationId])
  @@index([duplicateOfActionId])
  @@index([dedupedToTodoId])
  @@map("agent_actions")
}

/// Agent memory — rules, preferences, playbooks, style guides
