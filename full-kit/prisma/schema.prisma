// =============================================================================
// EXTERNAL INTEGRATIONS / SYNC TRACKING
// =============================================================================

/// Tracks external records imported from Plaud, Gmail, Google Calendar, etc.
/// Prevents duplicate imports and enables incremental sync.
model ExternalSync {
  id         String     @id @default(uuid())
  source     String // plaud, gmail, google-calendar, twilio, etc.
  externalId String     @map("external_id") // ID from the external system
  entityType String?    @map("entity_type") // communication, meeting, todo, deal
  entityId   String?    @map("entity_id") // UUID of the created entity
  syncedAt   DateTime   @default(now()) @map("synced_at")
  rawData    Json?      @map("raw_data") // original API response for debugging
  status     SyncStatus @default(synced)
  errorMsg   String?    @map("error_msg") @db.Text

  // Direct link back to communication (most common case)
  communication Communication?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, externalId])
  @@index([source])
  @@index([syncedAt])
  @@index([status])
  @@index([entityType, entityId])
  @@map("external_sync")
}

/// Integration credentials — store API tokens for external services
/// NOTE: The `credentials` JSON MUST be encrypted at the application layer
/// before writing. Never store plaintext tokens.
model IntegrationCredential {
  id            String    @id @default(uuid())
  service       String    @unique // plaud, gmail, google-calendar, etc.
  credentials   Json // { accessToken, refreshToken, expiresAt, ... } — ENCRYPTED
  scopes        String[]  @default([]) // permissions this credential grants
  encryptedAt   DateTime? @map("encrypted_at") // when credentials were last encrypted
  lastRefreshed DateTime? @map("last_refreshed")
  isActive      Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integration_credentials")
}
