datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

// =============================================================================
// ENUMS
// =============================================================================

enum Category {
  business
  personal
}

enum DealStage {
  prospecting
  listing
  marketing
  showings
  offer
  under_contract
  due_diligence
  closing
  closed
}

enum CanonicalDealStage {
  unknown
  prospect
  sourcing
  evaluating
  touring
  listing
  marketing
  loi_offer
  transacting
  under_contract
  due_diligence
  contingent
  closing
  closed
  dead
  nurture
  commission_realized
}

enum ContactPromotionCandidateStatus {
  pending
  needs_more_evidence
  snoozed
  approved
  merged
  rejected
  not_a_contact
  superseded
}

enum BuildoutEventKind {
  new_lead
  information_requested
  deal_stage_update
  task_assigned
  critical_date
  ca_executed
  document_view
  voucher_approved
  voucher_deposit
  commission_payment
  listing_expiration
  payment_event
  unknown_signal
}

enum BuildoutEventStatus {
  parsed
  matched
  needs_review
  proposed
  applied
  ignored
  superseded
  dead_letter
}

enum IntakeDispositionStatus {
  received
  normalized
  suppressed_noise
  filed_activity
  needs_human_gate
  queued_attention
  review_backlog
  dead_letter
  superseded
}

enum TodoReminderState {
  proposed
  active
  waiting_on_other
  snoozed
  due
  overdue
  done
  rejected
  superseded
}

enum AiFeedbackStatus {
  captured
  proposed_rule
  approved_rule
  rejected_rule
}

enum PropertyType {
  office
  retail
  industrial
  multifamily
  land
  mixed_use
  hospitality
  medical
  other
}

enum CommunicationChannel {
  email
  call
  text
  whatsapp
  meeting
}

enum Direction {
  inbound
  outbound
}

enum TodoStatus {
  pending
  in_progress
  done
}

enum Priority {
  low
  medium
  high
  urgent
}

enum AgentTier {
  auto
  log_only
  approve
  blocked
}

enum AgentActionStatus {
  pending
  approved
  rejected
  executed
}

enum MemoryType {
  rule
  preference
  playbook
  client_note
  style_guide
}

enum SyncStatus {
  synced
  failed
  pending
  removed
}

enum QueueStatus {
  pending
  in_flight
  done
  failed
}

enum LeadSource {
  crexi
  loopnet
  buildout
  email_cold
  referral
}

enum LeadStatus {
  new
  vetted
  contacted
  converted
  dropped
}

enum EmailFilterRuleMode {
  draft
  classification_only
  observe_only
  quarantine_candidate
  promoted_exact
  limited_rollout
  active
  disabled
  retired
}

enum EmailBodyDecision {
  fetch_body
  metadata_only_quarantine
  safe_body_skip
}

enum EmailFilterRunMode {
  dry_run
  observe
  quarantine_only
  promoted_rules_limited
  active
}

enum EmailFilterAuditDisposition {
  observed
  quarantined
  fetched_body
  body_fetch_failed
  safe_skip_proposed
  safe_skip_applied
  restored
  false_negative
  true_noise
  uncertain
}

// =============================================================================
// AUTH MODELS (existing — do not modify, required by NextAuth/PrismaAdapter)
// =============================================================================

model User {
  id                   String          @id @default(uuid())
  name                 String
  username             String?         @unique
  email                String?         @unique
  emailVerifyToken     String?
  emailVerified        DateTime?
  password             String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  avatar               String?
  profileBackground    String?
  status               String          @default("ONLINE")
  preferences          UserPreference?
  accounts             Account[]
  sessions             Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name, username, status, createdAt])
}

model UserPreference {
  id        String  @id @default(uuid())
  theme     String
  mode      String
  radius    String
  layout    String
  direction String
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String? @unique
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// CRE BUSINESS MODELS
// =============================================================================

/// Unified people table — both business clients and personal contacts.
/// Use `category` to distinguish business vs personal.
model Contact {
  id               String      @id @default(uuid())
  name             String
  company          String?
  email            String?
  phone            String?
  role             String? // e.g., "investor", "tenant", "dentist", "family"
  preferredContact String?     @map("preferred_contact") // email, phone, text, whatsapp
  address          String?
  notes            String?     @db.Text
  category         Category    @default(business)
  tags             Json?       @default("[]") // JSON array of tag strings
  createdBy        String?     @map("created_by") // "user:<id>" or "agent"
  archivedAt       DateTime?   @map("archived_at")
  leadSource       LeadSource? @map("lead_source")
  leadStatus       LeadStatus? @map("lead_status")
  leadAt           DateTime?   @map("lead_at")
  leadLastViewedAt DateTime?   @map("lead_last_viewed_at")
  estimatedValue   Decimal?    @map("estimated_value") @db.Decimal(14, 2)

  // Relations
  deals          Deal[]
  communications Communication[]
  meetings       MeetingAttendee[]
  todos          Todo[]
  agentMemories  AgentMemory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([company])
  @@index([category])
  @@index([leadSource])
  @@index([leadStatus])
  @@index([leadStatus, updatedAt])
  @@index([leadSource, leadStatus, leadLastViewedAt])
  @@map("contacts")
}

/// CRE deals — the core pipeline entity
model Deal {
  id              String       @id @default(uuid())
  contactId       String       @map("contact_id")
  propertyAddress String       @map("property_address")
  propertyType    PropertyType @map("property_type")
  squareFeet      Int?         @map("square_feet")
  stage           DealStage    @default(prospecting)
  value           Decimal?     @db.Decimal(14, 2)
  listedDate      DateTime?    @map("listed_date")
  closingDate     DateTime?    @map("closing_date")
  keyContacts     Json?        @default("{}") @map("key_contacts") // { role: name }
  category        Category     @default(business)
  tags            Json?        @default("[]")
  notes           String?      @db.Text
  createdBy       String?      @map("created_by")
  archivedAt      DateTime?    @map("archived_at")
  commissionRate  Decimal?     @default(0.03) @map("commission_rate") @db.Decimal(5, 4)
  probability     Int?
  stageChangedAt  DateTime?    @map("stage_changed_at")

  // Relations
  contact        Contact         @relation(fields: [contactId], references: [id], onDelete: Restrict)
  documents      DealDocument[]
  communications Communication[]
  meetings       Meeting[]
  todos          Todo[]
  agentMemories  AgentMemory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([stage])
  @@index([propertyType])
  @@index([propertyAddress])
  @@index([listedDate])
  @@index([closingDate])
  @@index([stageChangedAt])
  @@map("deals")
}

/// Documents/files attached to deals
model DealDocument {
  id        String   @id @default(uuid())
  dealId    String   @map("deal_id")
  name      String
  docType   String   @map("doc_type") // contract, inspection, financial, title, marketing, correspondence, other
  url       String? // cloud storage URL (Google Drive, S3, etc.)
  notes     String?
  dateAdded DateTime @default(now()) @map("date_added")

  // Relations
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([docType])
  @@map("deal_documents")
}

/// All communications: calls, texts, emails, WhatsApp, etc.
/// Primary table for Plaud transcripts, email bodies, SMS content.
model Communication {
  id                String               @id @default(uuid())
  channel           CommunicationChannel
  subject           String?
  body              String?              @db.Text // full transcript, email body, text content
  date              DateTime
  direction         Direction?
  category          Category             @default(business)
  tags              Json?                @default("[]")
  metadata          Json?                @default("{}") // flexible: extra channel-specific data
  durationSeconds   Int?                 @map("duration_seconds") // for calls
  externalMessageId String?              @map("external_message_id") // gmail msg id, etc.
  conversationId    String?              @map("conversation_id")
  createdBy         String?              @map("created_by")
  archivedAt        DateTime?            @map("archived_at")

  // Who and what this relates to
  contactId String? @map("contact_id")
  dealId    String? @map("deal_id")

  // Which agent action created this (if auto-generated)
  agentActionId String? @unique @map("agent_action_id")

  // Relations
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  agentAction AgentAction? @relation(fields: [agentActionId], references: [id], onDelete: SetNull)

  // Link to external sync record (for Plaud, Gmail, etc.)
  externalSyncId String?       @unique @map("external_sync_id")
  externalSync   ExternalSync? @relation(fields: [externalSyncId], references: [id])

  // Todos that were created from this communication
  todos      Todo[]
  scrubQueue ScrubQueue?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channel])
  @@index([date])
  @@index([contactId])
  @@index([dealId])
  @@index([direction])
  @@index([category])
  @@index([externalMessageId])
  @@index([conversationId])
  @@map("communications")
}

model IntakeDisposition {
  id               String                  @id @default(uuid())
  sourceSystem     String                  @map("source_system")
  sourceExternalId String                  @map("source_external_id")
  communicationId  String?                 @map("communication_id")
  status           IntakeDispositionStatus
  reasonCode       String                  @map("reason_code")
  confidence       Decimal?                @db.Decimal(5, 4)
  processor        String
  processorVersion String                  @map("processor_version")
  childRefs        Json?                   @default("[]") @map("child_refs")
  retryCount       Int                     @default(0) @map("retry_count")
  lastError        String?                 @map("last_error") @db.Text
  metadata         Json?                   @default("{}")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  @@unique([sourceSystem, sourceExternalId])
  @@index([communicationId])
  @@index([status])
  @@map("intake_dispositions")
}

model IdentityCandidateGroup {
  id                String                          @id @default(uuid())
  status            ContactPromotionCandidateStatus @default(pending)
  displayName       String?                         @map("display_name")
  normalizedEmails  Json?                           @default("[]") @map("normalized_emails")
  normalizedPhones  Json?                           @default("[]") @map("normalized_phones")
  aliases           Json?                           @default("[]")
  companies         Json?                           @default("[]")
  evidence          Json?                           @default("[]")
  possibleContactId String?                         @map("possible_contact_id")
  approvedContactId String?                         @map("approved_contact_id")
  confidenceScore   Decimal?                        @map("confidence_score") @db.Decimal(5, 4)
  snoozedUntil      DateTime?                       @map("snoozed_until")
  metadata          Json?                           @default("{}")
  createdAt         DateTime                        @default(now()) @map("created_at")
  updatedAt         DateTime                        @updatedAt @map("updated_at")

  @@index([status])
  @@index([possibleContactId])
  @@index([approvedContactId])
  @@map("identity_candidate_groups")
}

model ContactPromotionCandidate {
  id                       String                          @id @default(uuid())
  identityCandidateGroupId String?                         @map("identity_candidate_group_id")
  normalizedEmail          String?                         @map("normalized_email")
  displayName              String?                         @map("display_name")
  company                  String?
  phone                    String?
  message                  String?                         @db.Text
  source                   String
  sourcePlatform           String?                         @map("source_platform")
  sourceKind               String?                         @map("source_kind")
  status                   ContactPromotionCandidateStatus @default(pending)
  confidenceScore          Decimal?                        @map("confidence_score") @db.Decimal(5, 4)
  evidenceCount            Int                             @default(1) @map("evidence_count")
  firstSeenAt              DateTime                        @default(now()) @map("first_seen_at")
  lastSeenAt               DateTime                        @default(now()) @map("last_seen_at")
  suggestedContactId       String?                         @map("suggested_contact_id")
  approvedContactId        String?                         @map("approved_contact_id")
  communicationId          String?                         @map("communication_id")
  agentActionId            String?                         @map("agent_action_id")
  dedupeKey                String                          @unique @map("dedupe_key")
  snoozedUntil             DateTime?                       @map("snoozed_until")
  metadata                 Json?                           @default("{}")
  createdAt                DateTime                        @default(now()) @map("created_at")
  updatedAt                DateTime                        @updatedAt @map("updated_at")

  @@index([identityCandidateGroupId])
  @@index([normalizedEmail])
  @@index([status])
  @@index([snoozedUntil])
  @@index([communicationId])
  @@map("contact_promotion_candidates")
}

model BuildoutProperty {
  id                    String              @id @default(uuid())
  buildoutPropertyId    String?             @unique @map("buildout_property_id")
  buildoutDealId        String?             @unique @map("buildout_deal_id")
  propertyNameRaw       String?             @map("property_name_raw")
  propertyAddressRaw    String?             @map("property_address_raw")
  normalizedPropertyKey String              @map("normalized_property_key")
  aliases               Json?               @default("[]")
  unitOrSuite           String              @default("") @map("unit_or_suite")
  currentStage          CanonicalDealStage? @map("current_stage")
  status                String              @default("unknown")
  source                String              @default("email_event")
  assignedToMatt        Boolean             @default(false) @map("assigned_to_matt")
  teamMembers           Json?               @default("[]") @map("team_members")
  sourceRecipients      Json?               @default("[]") @map("source_recipients")
  lastBuildoutEventAt   DateTime?           @map("last_buildout_event_at")
  matchedDealId         String?             @map("matched_deal_id")
  matchConfidence       Decimal?            @map("match_confidence") @db.Decimal(5, 4)
  metadata              Json?               @default("{}")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@unique([normalizedPropertyKey, unitOrSuite])
  @@index([matchedDealId])
  @@map("buildout_properties")
}

model BuildoutEvent {
  id                    String              @id @default(uuid())
  communicationId       String?             @map("communication_id")
  sourceExternalId      String?             @map("source_external_id")
  eventKind             BuildoutEventKind   @map("event_kind")
  status                BuildoutEventStatus @default(parsed)
  propertyNameRaw       String?             @map("property_name_raw")
  propertyAddressRaw    String?             @map("property_address_raw")
  normalizedPropertyKey String?             @map("normalized_property_key")
  buildoutPropertyId    String?             @map("buildout_property_id")
  buildoutDealId        String?             @map("buildout_deal_id")
  inquirerName          String?             @map("inquirer_name")
  inquirerEmail         String?             @map("inquirer_email")
  inquirerPhone         String?             @map("inquirer_phone")
  inquirerMessage       String?             @map("inquirer_message") @db.Text
  viewerName            String?             @map("viewer_name")
  viewerEmail           String?             @map("viewer_email")
  viewerCompany         String?             @map("viewer_company")
  taskTitle             String?             @map("task_title")
  taskDueDate           DateTime?           @map("task_due_date")
  taskAssignee          String?             @map("task_assignee")
  criticalDate          DateTime?           @map("critical_date")
  deadlineType          String?             @map("deadline_type")
  sourceStageRaw        String?             @map("source_stage_raw")
  previousStageRaw      String?             @map("previous_stage_raw")
  newStageRaw           String?             @map("new_stage_raw")
  canonicalStage        CanonicalDealStage? @map("canonical_stage")
  documentName          String?             @map("document_name")
  documentUrl           String?             @map("document_url") @db.Text
  amount                Decimal?            @db.Decimal(14, 2)
  paymentStatus         String?             @map("payment_status")
  voucherId             String?             @map("voucher_id")
  voucherName           String?             @map("voucher_name")
  invoiceId             String?             @map("invoice_id")
  payerName             String?             @map("payer_name")
  matchedDealId         String?             @map("matched_deal_id")
  matchedContactId      String?             @map("matched_contact_id")
  matchConfidence       Decimal?            @map("match_confidence") @db.Decimal(5, 4)
  dedupeKey             String?             @unique @map("dedupe_key")
  metadata              Json?               @default("{}")
  eventAt               DateTime?           @map("event_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([communicationId])
  @@index([eventKind])
  @@index([status])
  @@index([normalizedPropertyKey])
  @@index([matchedDealId])
  @@map("buildout_events")
}

model TodoReminderPolicy {
  id              String            @id @default(uuid())
  todoId          String?           @map("todo_id")
  agentActionId   String?           @map("agent_action_id")
  communicationId String?           @map("communication_id")
  dedupeKey       String?           @map("dedupe_key")
  state           TodoReminderState @default(proposed)
  cadence         String            @default("once")
  nextReminderAt  DateTime?         @map("next_reminder_at")
  lastReminderAt  DateTime?         @map("last_reminder_at")
  snoozedUntil    DateTime?         @map("snoozed_until")
  lastEvidenceAt  DateTime?         @map("last_evidence_at")
  sourcePolicy    String?           @map("source_policy")
  policyReason    String?           @map("policy_reason") @db.Text
  metadata        Json?             @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([todoId])
  @@index([agentActionId])
  @@index([communicationId])
  @@index([state])
  @@index([nextReminderAt])
  @@map("todo_reminder_policies")
}

model AiFeedback {
  id               String           @id @default(uuid())
  sourceType       String           @map("source_type")
  sourceId         String           @map("source_id")
  modelUsed        String?          @map("model_used")
  promptVersion    String?          @map("prompt_version")
  predictedLabel   String?          @map("predicted_label")
  predictedAction  String?          @map("predicted_action")
  correctedLabel   String?          @map("corrected_label")
  correctedAction  String?          @map("corrected_action")
  reason           String?          @db.Text
  status           AiFeedbackStatus @default(captured)
  createdBy        String?          @map("created_by")
  promotedToRuleAt DateTime?        @map("promoted_to_rule_at")
  regressionTestId String?          @map("regression_test_id")
  metadata         Json?            @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@index([sourceType, sourceId])
  @@index([status])
  @@map("ai_feedback")
}

/// Calendar events and meetings
model Meeting {
  id              String    @id @default(uuid())
  title           String
  date            DateTime
  endDate         DateTime? @map("end_date")
  durationMinutes Int?      @map("duration_minutes")
  location        String?
  notes           String?   @db.Text
  category        Category  @default(business)
  tags            Json?     @default("[]")
  metadata        Json?     @default("{}") // { google_calendar_id, zoom_link, etc. }
  createdBy       String?   @map("created_by")
  archivedAt      DateTime? @map("archived_at")

  dealId String? @map("deal_id")

  // Which agent action created this (if auto-generated)
  agentActionId String? @unique @map("agent_action_id")

  // Relations
  deal        Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  agentAction AgentAction?      @relation(fields: [agentActionId], references: [id], onDelete: SetNull)
  attendees   MeetingAttendee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([dealId])
  @@index([category])
  @@map("meetings")
}

/// Meeting attendees — supports multiple participants per meeting
model MeetingAttendee {
  id        String  @id @default(uuid())
  meetingId String  @map("meeting_id")
  contactId String? @map("contact_id")
  role      String? // organizer, attendee, optional

  meeting Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([meetingId, contactId])
  @@map("meeting_attendees")
}

/// Tasks / to-do items
model Todo {
  id         String     @id @default(uuid())
  title      String
  body       String?    @db.Text
  status     TodoStatus @default(pending)
  priority   Priority   @default(medium)
  dueDate    DateTime?  @map("due_date")
  category   Category   @default(business)
  tags       Json?      @default("[]")
  createdBy  String?    @map("created_by")
  archivedAt DateTime?  @map("archived_at")

  // What this todo relates to
  contactId       String? @map("contact_id")
  dealId          String? @map("deal_id")
  communicationId String? @map("communication_id")

  // Which agent action created this (if auto-generated)
  agentActionId String? @unique @map("agent_action_id")

  // Relations
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal          Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  communication Communication? @relation(fields: [communicationId], references: [id], onDelete: SetNull)
  agentAction   AgentAction?   @relation(fields: [agentActionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([contactId])
  @@index([dealId])
  @@index([communicationId])
  @@index([category])
  @@map("todos")
}

/// Reusable message templates (emails, texts, follow-ups)
model Template {
  id      String                @id @default(uuid())
  name    String                @unique
  channel CommunicationChannel?
  subject String?
  useCase String?               @map("use_case")
  body    String                @db.Text
  tags    Json?                 @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([useCase])
  @@index([channel])
  @@map("templates")
}

// =============================================================================
// AGENT SYSTEM
// =============================================================================

/// Agent actions — the approval queue for AI-generated tasks
model AgentAction {
  id           String            @id @default(uuid())
  actionType   String            @map("action_type") // create-todo, update-deal, send-email, etc.
  tier         AgentTier
  status       AgentActionStatus @default(pending)
  summary      String // human-readable description
  targetEntity String?           @map("target_entity") // e.g., "deal:<uuid>" or "contact:<uuid>"
  payload      Json?             @default("{}") // structured action data
  feedback     String?           @db.Text

  executedAt DateTime? @map("executed_at")

  // Relations: which entity did this action create?
  todo          Todo?
  communication Communication?
  meeting       Meeting?
  memory        AgentMemory?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([tier])
  @@index([actionType])
  @@index([createdAt])
  @@map("agent_actions")
}

/// Agent memory — rules, preferences, playbooks, style guides
model AgentMemory {
  id         String     @id @default(uuid())
  memoryType MemoryType @map("memory_type")
  title      String
  content    String     @db.Text // markdown content
  priority   Priority?
  tags       Json?      @default("[]")

  // Optional: link memory to a specific client or deal
  contactId     String? @map("contact_id")
  dealId        String? @map("deal_id")
  agentActionId String? @unique @map("agent_action_id")

  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  agentAction AgentAction? @relation(fields: [agentActionId], references: [id], onDelete: SetNull)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime? @map("last_used_at")

  @@index([memoryType])
  @@index([priority])
  @@index([contactId])
  @@index([dealId])
  @@map("agent_memory")
}

model ScrubQueue {
  id              String      @id @default(uuid())
  communicationId String      @unique @map("communication_id")
  enqueuedAt      DateTime    @default(now()) @map("enqueued_at")
  status          QueueStatus @default(pending)
  attempts        Int         @default(0)
  lockedUntil     DateTime?   @map("locked_until")
  leaseToken      String?     @map("lease_token")
  lastError       String?     @map("last_error") @db.Text
  promptVersion   String?     @map("prompt_version")

  communication Communication  @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  apiCalls      ScrubApiCall[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, enqueuedAt])
  @@index([lockedUntil])
  @@map("scrub_queue")
}

model ScrubApiCall {
  id               String   @id @default(uuid())
  scrubQueueId     String?  @map("scrub_queue_id")
  communicationId  String?  @map("communication_id")
  promptVersion    String   @map("prompt_version")
  modelUsed        String   @map("model_used")
  tokensIn         Int      @map("tokens_in")
  tokensOut        Int      @map("tokens_out")
  cacheReadTokens  Int      @default(0) @map("cache_read_tokens")
  cacheWriteTokens Int      @default(0) @map("cache_write_tokens")
  outcome          String
  estimatedUsd     Decimal  @map("estimated_usd") @db.Decimal(10, 6)
  at               DateTime @default(now())

  scrubQueue ScrubQueue? @relation(fields: [scrubQueueId], references: [id], onDelete: SetNull)

  @@index([at])
  @@index([communicationId])
  @@map("scrub_api_calls")
}

model EmailFilterRule {
