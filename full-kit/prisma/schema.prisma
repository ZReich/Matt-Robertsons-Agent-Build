  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dedupeKey String? @map("dedupe_key")

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([contactId])
  @@index([dealId])
  @@index([communicationId])
  @@index([category])
  @@index([dedupeKey])
  @@map("todos")
}

