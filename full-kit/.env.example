BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# --- Postgres (Supabase) ---
# Pooled connection (port 6543, with pgbouncer=true). Used by the Next.js app at runtime.
DATABASE_URL=postgresql://postgres:REDACTED@aws-X-region-X.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (port 5432, no pooler). REQUIRED for `prisma migrate diff` and
# `prisma migrate resolve` — pgbouncer hangs those commands indefinitely on Windows.
DIRECT_URL=postgresql://postgres:REDACTED@aws-X-region-X.pooler.supabase.com:5432/postgres
# Shadow database for `prisma migrate dev` / `migrate diff --shadow-database-url`.
# MUST be a separate empty Postgres database. Prisma resets and re-applies migrations
# to it to compute diffs — pointing this at the production DB will WIPE PRODUCTION DATA.
# Recommended: a second Supabase project on free tier, OR a local Postgres in Docker.
SHADOW_DATABASE_URL=postgresql://postgres:REDACTED@<shadow-host>:5432/postgres

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

HOME_PATHNAME=/dashboards/analytics
NEXT_PUBLIC_HOME_PATHNAME=/dashboards/analytics

# --- Microsoft Graph (Outlook) integration ---
# Credentials issued by NAI's IT provider (Entre) for the Azure AD app registration.
# Real values live in .env.local (gitignored). These are placeholders for onboarding.
MSGRAPH_TENANT_ID=REDACTED
MSGRAPH_CLIENT_ID=REDACTED
MSGRAPH_CLIENT_SECRET=REDACTED
# Matt's Microsoft login (user principal name), e.g. matt.robertson@nai-example.com
MSGRAPH_TARGET_UPN=REDACTED
# Long random string. Required as x-admin-token header on /api/integrations/msgraph/test.
# Generate with: openssl rand -hex 32
MSGRAPH_TEST_ADMIN_TOKEN=REDACTED
# Kill switch for the test route. Must be exactly "true" to enable. Anything else => 404.
MSGRAPH_TEST_ROUTE_ENABLED=false

# Comma-separated reviewer allowlists for /pages/contact-candidates and candidate action APIs.
# Candidate promotion fails closed unless at least one allowlist contains the signed-in user.
CONTACT_CANDIDATE_REVIEWER_EMAILS=matt.robertson@example.com,zach@example.com
CONTACT_CANDIDATE_REVIEWER_IDS=

# Comma-separated reviewer allowlists for Prisma AgentAction review APIs.
# CONTACT_CANDIDATE_* values are accepted here as one-way rollout aliases,
# but AGENT_ACTION_* values do not grant contact-candidate promotion access.
AGENT_ACTION_REVIEWER_EMAILS=matt.robertson@example.com,zach@example.com
AGENT_ACTION_REVIEWER_IDS=

# Daily rolling 24-hour cap for manual AI-suggestion processing/reprocessing.
# Audit I4: this cap covers ONLY the live scrub pipeline (Haiku-backed).
# Lease-pipeline outcomes (classifier-, extractor-, extractor-pdf-) are
# excluded from this rolling sum and counted against the separate
# LEASE_BACKFILL_DAILY_BUDGET_USD below.
SCRUB_DAILY_BUDGET_USD=5

# Daily rolling 24-hour cap for the lease-backfill pipeline (DeepSeek
# classifier + Haiku body extractor + Haiku PDF extractor). Sized to the
# spec's $30/day backfill estimate so a 200K-row sweep can drain over
# multiple days without starving the live scrub budget.
LEASE_BACKFILL_DAILY_BUDGET_USD=30

# =============================================================================
# AI providers
# =============================================================================
#
# Anthropic — when ANTHROPIC_API_KEY is non-empty, scrub-provider.ts uses
# Claude (Haiku 4.5 by default) instead of falling through to OpenAI/DeepSeek.
# Sign up: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=
ANTHROPIC_LEASE_EXTRACTOR_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_PDF_LEASE_MODEL=claude-haiku-4-5-20251001
# When true (and key is set), sensitive emails route to Haiku instead of
# being skipped entirely. Default false — start by reviewing them manually.
ROUTE_SENSITIVE_TO_CLAUDE=false

# OpenAI / OpenAI-compatible (DeepSeek, xAI, Ollama all work via base URL).
# Used as fallback when ANTHROPIC_API_KEY is empty, and used directly by
# the contact-summary, criteria-extractor, and closed-deal-classifier stubs
# (those keep DeepSeek for cheap broad-scan reasons).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SCRUB_MODEL=gpt-4o-mini
